# STAGE 1: The Builder (Compiling your NestJS)
FROM node:20-alpine AS builder

WORKDIR /app

# Only copy package files first to leverage Docker's layer caching
COPY package*.json ./
RUN npm install

# Copy everything else and build the project
COPY . .
RUN npm run build

# STAGE 2: The Runner (The lightweight final image)
FROM node:20-alpine AS runner

WORKDIR /app

# Set to production to optimize NestJS performance
ENV NODE_ENV=production

# Copy only the compiled code and production-only dependencies
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package*.json ./
RUN npm ci --omit=dev

# NestJS typically runs on 3000
EXPOSE 3000

CMD ["node", "dist/main"]